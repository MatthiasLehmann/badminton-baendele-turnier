# ============================================================
# Bändelturnier – Umgebungsvariablen
# ============================================================
# Datei kopieren: cp .env.example .env
# Dann die Werte mit deinen Supabase-Credentials befüllen.
#
# Supabase-Credentials findest du unter:
#   Dashboard → Project Settings → API
# ============================================================

# Supabase Projekt-URL (endet auf .supabase.co)
VITE_SUPABASE_URL=https://DEIN-PROJEKT-ID.supabase.co

# Supabase Anon-Key (öffentlicher API-Schlüssel, kein Geheimnis)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
